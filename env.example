# Telegram Bot Token (получить у @BotFather)
TELEGRAM_TOKEN=your_bot_token_here

# Together.ai API Key (https://api.together.xyz)
TOGETHER_API_KEY=your_together_key_here

# OpenRouter API Key (https://openrouter.ai) — бесплатный tier
OPENROUTER_API_KEY=your_openrouter_key_here

# Hailuo/MiniMax API Key (https://www.minimaxi.com) — бесплатный tier
HAILUO_API_KEY=your_hailuo_key_here

# Опционально: ограничить доступ (через запятую без пробелов)
# ALLOWED_USER_IDS=123456789,987654321

# Опционально: лимиты и throttling
# MAX_CONVERSATION_MESSAGES=20
# MAX_HISTORY_ITEMS=50
# THROTTLE_RATE=0.5
